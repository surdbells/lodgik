# ===========================================
# Lodgik — Environment Configuration Template
# Copy to .env and fill in your values.
# chmod 600 .env before running in production.
# ===========================================

# ─── Application ─────────────────────────────────────────────────
APP_NAME=Lodgik
APP_ENV=production
# !! CRITICAL: MUST be false in production — true exposes stack traces publicly
APP_DEBUG=false
APP_URL=https://api.lodgik.co
APP_SECRET=<generate: openssl rand -hex 32>
MERCHANT_APP_URL=https://merchant.lodgik.co
HOTEL_APP_URL=https://hotel.lodgik.co

# ─── Database (PostgreSQL) ────────────────────────────────────────
DB_DRIVER=pdo_pgsql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lodgik
DB_USER=lodgik_app
DB_PASSWORD=<strong-password>
DB_CHARSET=utf8

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=<strong-password>
REDIS_PREFIX=lodgik:

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=<generate: openssl rand -hex 32>
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ─── PII Encryption (field-level AES-256-GCM) ────────────────────
# Generate with: openssl rand -hex 32
# Required to encrypt guest phone, ID numbers, and employee bank account numbers at rest.
# After setting, run: php bin/encrypt-pii.php --dry-run && php bin/encrypt-pii.php --apply
PII_ENCRYPTION_KEY=<generate: openssl rand -hex 32>

# ─── ZeptoMail (Transactional Email) ─────────────────────────────
ZEPTOMAIL_API_KEY=Zoho-enczapikey <your-send-mail-token>
ZEPTOMAIL_FROM_EMAIL=noreply@lodgik.co
ZEPTOMAIL_FROM_NAME=Lodgik

# ─── Termii (SMS / WhatsApp) ─────────────────────────────────────
TERMII_API_KEY=<api-key>
TERMII_SENDER_ID=Lodgik

# ─── Paystack (Subscription billing only) ────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=<generate: openssl rand -hex 32>

# ─── File Storage (Flysystem) ────────────────────────────────────
#
# STORAGE_DRIVER — choose one: local | s3
#
#   local:
#     Files are stored on the server at STORAGE_PATH.
#     Nginx serves them publicly at /storage (see Nginx config in DEPLOYMENT_RUNBOOK.md).
#     STORAGE_URL must point to the publicly reachable base URL.
#
#   s3:
#     Files are stored in AWS S3 (private bucket).
#     All download URLs are pre-signed (time-limited).
#     Set AWS_S3_* variables below. STORAGE_URL is ignored for S3.
#
STORAGE_DRIVER=local

# ── Local driver config ──────────────────────────────────────────
# Absolute path on the server where files are written.
STORAGE_PATH=/www/wwwroot/lodgik/storage
# Public base URL that Nginx maps to STORAGE_PATH.
# Required for the local driver — without this, URLs will be relative.
STORAGE_URL=https://api.lodgik.co/storage

# ── S3 driver config ─────────────────────────────────────────────
# Leave blank if using local driver.
AWS_S3_BUCKET=
AWS_S3_REGION=ap-southeast-1
AWS_S3_KEY=
AWS_S3_SECRET=
# Optional: prefix all stored keys with this path inside the bucket.
# e.g. AWS_S3_PREFIX=lodgik/production
AWS_S3_PREFIX=

# ─── CORS ────────────────────────────────────────────────────────
# !! Comma-separated list of allowed origins.
# !! In production, list your actual domains — NOT localhost.
CORS_ALLOWED_ORIGINS=https://hotel.lodgik.co,https://admin.lodgik.co,https://merchant.lodgik.co
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID

# ─── Logging ─────────────────────────────────────────────────────
LOG_CHANNEL=stderr
# !! In production use warning or error — debug leaks sensitive data
LOG_LEVEL=warning
LOG_PATH=./logs

# ─── Sentry Error Monitoring ────────────────────────────
# Get DSN from https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=
