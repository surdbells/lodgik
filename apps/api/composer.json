{
    "name": "lodgik/api",
    "description": "Lodgik - Hospitality Operating System API",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "doctrine/dbal": "^4.2",
        "doctrine/migrations": "^3.8",
        "doctrine/orm": "^3.3",
        "dompdf/dompdf": "^3.0",
        "firebase/php-jwt": "^6.10",
        "league/flysystem": "^3.0",
        "league/flysystem-local": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.0",
        "aws/aws-sdk-php": "^3.0",
        "monolog/monolog": "^3.7",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "predis/predis": "^2.2",
        "ramsey/uuid": "^4.7",
        "slim/psr7": "^1.7",
        "slim/slim": "^4.14",
        "symfony/cache": "^7.2",
        "symfony/console": "^7.2",
        "symfony/messenger": "^7.2",
        "symfony/validator": "^7.2",
        "vlucas/phpdotenv": "^5.6",
        "zircote/swagger-php": "^4.11",
        "sentry/sentry": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.4",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.64",
        "symfony/var-dumper": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "Lodgik\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lodgik\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse src --level=6"
    }
}