# Lodgik — Production Cron Schedule (aaPanel / Bare Metal)
# =========================================================
# Install:  crontab -e  (as root or www user)
# Verify:   crontab -l
#
# PHP binary: /www/server/php/83/bin/php
# Project:    /www/wwwroot/lodgik/apps/api
# Logs:       /www/wwwroot/lodgik/logs/cron/
# =========================================================

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
LODGIK=/www/wwwroot/lodgik/apps/api
PHP=/www/server/php/83/bin/php

# ── Ensure log directory exists ───────────────────────────
# Run once manually: mkdir -p /www/wwwroot/lodgik/logs/cron

# ── 01:00 AM — Fraud auto-checkout ────────────────────────
# Checks for bookings overdue by >2h and auto-checks them out.
# Must run BEFORE night audit so revenue totals are accurate.
0 1 * * * cd $LODGIK && $PHP bin/console lodgik:fraud-auto-checkout >> /www/wwwroot/lodgik/logs/cron/fraud-checkout.log 2>&1

# ── 02:00 AM — Night audit ────────────────────────────────
# Generates DailySnapshot for all active properties.
# Posts nightly room charges to open folios.
0 2 * * * cd $LODGIK && $PHP bin/console lodgik:night-audit >> /www/wwwroot/lodgik/logs/cron/night-audit.log 2>&1

# ── 02:30 AM — Database backup ────────────────────────────
# pg_dump → AES-256 encrypted → /www/backup/lodgik_YYYYMMDD.dump.gz.enc
# Retains 30 days. Upload to remote storage manually or via rclone.
30 2 * * * cd $LODGIK && $PHP bin/console lodgik:db-backup >> /www/wwwroot/lodgik/logs/cron/backup.log 2>&1

# ── 12:00 PM — Noon checkout reminder ─────────────────────
# Sends SMS/push reminder to guests with noon checkout.
0 12 * * * cd $LODGIK && $PHP bin/console lodgik:noon-checkout >> /www/wwwroot/lodgik/logs/cron/noon-checkout.log 2>&1

# ── 12:30 PM — Late checkout charges ─────────────────────
# Posts late-checkout fee to folio for guests still checked in after noon.
30 12 * * * cd $LODGIK && $PHP bin/console lodgik:late-checkout-charge >> /www/wwwroot/lodgik/logs/cron/late-checkout.log 2>&1

# ── Every 30 min — Visitor overstay check ────────────────
# Flags visitor access codes that have exceeded their valid window.
*/30 * * * * cd $LODGIK && $PHP bin/console lodgik:visitor-overstay >> /www/wwwroot/lodgik/logs/cron/visitor-overstay.log 2>&1
